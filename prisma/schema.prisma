// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Pode ser trocado para "sqlite" ou "mysql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------

enum Role {
  ADMIN
  ENFERMEIRO
  CUIDADOR
}

enum ShiftType {
  DIURNO
  NOTURNO
}

enum MedicationRoute {
  ORAL
  INTRAVENOSA
  INTRAMUSCULAR
  TOPICA
  SUBLINGUAL
  OUTRA
}

enum StockTransactionType {
  ENTRADA
  SAIDA
  DESCARTE
}

// ----------------------------------------------------------------------
// MODELS
// ----------------------------------------------------------------------

// 1. Usuários (Admin, Enfermeiro, Cuidador)
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CUIDADOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  shiftAssignments ShiftAssignment[]
  shiftHandovers   ShiftHandover[]   @relation("HandoverCreator")
  handoversReceived ShiftHandover[]  @relation("HandoverReceiver")
  stockMovements   StockMovement[]
  administrations  MedicationAdministration[]
  incidentReports  IncidentReport[]
  vitalSigns       VitalSigns[]
}

// 2. Moradores (Nome, idade, alergias, contatos de emergência, CID)
model Resident {
  id               String   @id @default(uuid())
  name             String
  dateOfBirth      DateTime
  allergies        String?  // Pode ser uma lista separada por vírgula ou JSON
  emergencyContact String
  emergencyPhone   String
  cid              String?  // Classificação Internacional de Doenças
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relações
  prescriptions    Prescription[]
  incidentReports  IncidentReport[]
  vitalSigns       VitalSigns[]
}

// 3. Medicamentos e Prescrições
model Medication {
  id          String   @id @default(uuid())
  name        String
  dosage      String   // Ex: 50mg, 10ml
  description String?
  stock       Int      @default(0)
  minStock    Int      @default(10) // Alerta de estoque baixo
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  prescriptions  Prescription[]
  stockMovements StockMovement[]
}

// Movimentação de Estoque de Medicamentos
model StockMovement {
  id           String               @id @default(uuid())
  medicationId String
  userId       String
  type         StockTransactionType
  quantity     Int
  reason       String?
  createdAt    DateTime             @default(now())

  medication Medication @relation(fields: [medicationId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
}

// Prescrição de Medicamentos para o Morador
model Prescription {
  id              String          @id @default(uuid())
  residentId      String
  medicationId    String
  instructions    String          // Ex: "1 comprimido a cada 8 horas"
  frequencyHours  Int?            // Ex: 8, 12, 24
  route           MedicationRoute @default(ORAL)
  startDate       DateTime
  endDate         DateTime?       // Se nulo, uso contínuo
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  resident        Resident        @relation(fields: [residentId], references: [id])
  medication      Medication      @relation(fields: [medicationId], references: [id])
  administrations MedicationAdministration[]
}

// Registro de Administração do Medicamento (Dado na hora X pelo Cuidador Y)
model MedicationAdministration {
  id             String   @id @default(uuid())
  prescriptionId String
  userId         String
  administeredAt DateTime @default(now())
  status         String   // Ex: "ADMINISTRADO", "RECUSADO", "ESQUECIDO"
  notes          String?

  prescription Prescription @relation(fields: [prescriptionId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

// 4. Plantões e Escalas de Funcionários
model Shift {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  type      ShiftType
  createdAt DateTime @default(now())

  assignments ShiftAssignment[]
  handovers   ShiftHandover[]
}

model ShiftAssignment {
  id        String   @id @default(uuid())
  shiftId   String
  userId    String
  startTime DateTime
  endTime   DateTime

  shift Shift @relation(fields: [shiftId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

// 5. Despensa e Cardápio (Estoque de alimentos)
model FoodItem {
  id          String   @id @default(uuid())
  name        String
  category    String   // Ex: "Grãos", "Carnes", "Hortifruti"
  quantity    Float
  unit        String   // Ex: "kg", "litros", "unidades"
  minQuantity Float    @default(5)
  expiration  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Menu {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  mealType  String   // Ex: "Café da Manhã", "Almoço", "Jantar"
  items     String   // Descrição do que será servido
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 6. Relatórios e Passagem de Plantão
model ShiftHandover {
  id         String   @id @default(uuid())
  shiftId    String
  authorId   String
  receiverId String?
  content    String   @db.Text // Texto descritivo da passagem
  urgentFlag Boolean  @default(false)
  createdAt  DateTime @default(now())

  shift    Shift @relation(fields: [shiftId], references: [id])
  author   User  @relation("HandoverCreator", fields: [authorId], references: [id])
  receiver User? @relation("HandoverReceiver", fields: [receiverId], references: [id])
}

// Relatórios de Incidentes (Quedas, surtos, etc)
model IncidentReport {
  id          String   @id @default(uuid())
  residentId  String?
  reporterId  String
  title       String
  description String   @db.Text
  dateOfEvent DateTime
  severity    String   // Ex: "BAIXA", "MEDIA", "ALTA"
  createdAt   DateTime @default(now())

  resident Resident? @relation(fields: [residentId], references: [id])
  reporter User      @relation(fields: [reporterId], references: [id])
}

// 7. Sinais Vitais (NOVO)
model VitalSigns {
  id               String   @id @default(uuid())
  residentId       String
  userId           String
  bloodPressure    String?  // Ex: "120/80"
  bloodGlucose     Int?     // Ex: 90
  temperature      Float?   // Ex: 36.5
  oxygenSaturation Int?     // Ex: 98
  measuredAt       DateTime @default(now())

  resident Resident @relation(fields: [residentId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}
